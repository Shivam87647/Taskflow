---
import '../styles/global.css';
interface Props {
	title?: string;
}
const { title = "Taskflow — Developer Task Manager" } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- Google Fonts for premium Geist-like typography equivalents -->
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,500;0,600;1,400&family=JetBrains+Mono&display=swap" rel="stylesheet">
		
		<title>{title}</title>
	</head>
	<body class="bg-canvas-soft text-ink min-h-screen flex flex-col font-sans antialiased select-none">
		<slot />
	</body>
</html>
