---
// CommandBar component for keyboard-driven shortcuts (Cmd+K console)
---
<div 
  id="command-bar-modal" 
  class="fixed inset-0 z-50 bg-primary/20 backdrop-blur-sm flex items-start justify-center pt-24 px-4 hidden transition-opacity duration-200"
  style="width: 100vw; height: 100vh;"
>
  <!-- Modal card -->
  <div 
    class="w-full max-w-lg bg-canvas rounded-lg shadow-level5 border border-hairline overflow-hidden flex flex-col transform scale-95 opacity-0 transition-all duration-200"
    id="command-bar-card"
  >
    <!-- Search / Command input -->
    <div class="flex items-center px-4 border-b border-hairline relative">
      <svg class="w-5 h-5 text-mute flex-shrink-0 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
      </svg>
      <input 
        type="text" 
        id="command-bar-input" 
        placeholder="Type a command or search tasks..." 
        class="w-full py-4 bg-transparent border-0 text-ink text-sm font-sans focus:outline-hidden focus:ring-0 placeholder:text-mute"
        autocomplete="off"
      />
      <div class="flex items-center gap-1">
        <kbd class="px-1.5 py-0.5 text-[10px] font-mono bg-canvas-soft border border-hairline rounded-sm text-mute shadow-xs">ESC</kbd>
      </div>
    </div>

    <!-- Suggested Commands / Results list -->
    <div 
      id="command-bar-results" 
      class="max-h-72 overflow-y-auto p-2 divide-y divide-transparent font-sans"
    >
      <!-- Option Template (Add Task) -->
      <div class="command-option flex items-center justify-between p-3 rounded-md hover:bg-canvas-soft-2 cursor-pointer text-sm text-ink font-medium select-none group" data-command="add">
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 text-xs font-mono bg-violet-soft/30 text-violet-deep border border-violet-soft/20 rounded-sm">/add</span>
          <span class="text-body group-hover:text-ink">Create new task <span class="text-mute font-normal text-xs ml-1">(e.g., /add Refactor auth)</span></span>
        </div>
        <span class="text-xs font-mono text-mute bg-canvas-soft border border-hairline px-1 rounded-sm hidden group-hover:block">↵</span>
      </div>

      <!-- Option Template (Complete Task) -->
      <div class="command-option flex items-center justify-between p-3 rounded-md hover:bg-canvas-soft-2 cursor-pointer text-sm text-ink font-medium select-none group" data-command="complete">
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 text-xs font-mono bg-cyan-soft/30 text-cyan-deep border border-cyan-soft/20 rounded-sm">/done</span>
          <span class="text-body group-hover:text-ink">Mark task as complete <span class="text-mute font-normal text-xs ml-1">(e.g., /done 1)</span></span>
        </div>
        <span class="text-xs font-mono text-mute bg-canvas-soft border border-hairline px-1 rounded-sm hidden group-hover:block">↵</span>
      </div>

      <!-- Option Template (Delete Task) -->
      <div class="command-option flex items-center justify-between p-3 rounded-md hover:bg-canvas-soft-2 cursor-pointer text-sm text-ink font-medium select-none group" data-command="delete">
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 text-xs font-mono bg-error-soft/30 text-error-deep border border-error-soft/20 rounded-sm">/delete</span>
          <span class="text-body group-hover:text-ink">Delete a task permanently <span class="text-mute font-normal text-xs ml-1">(e.g., /delete 2)</span></span>
        </div>
        <span class="text-xs font-mono text-mute bg-canvas-soft border border-hairline px-1 rounded-sm hidden group-hover:block">↵</span>
      </div>

      <!-- Option Template (Project Switch) -->
      <div class="command-option flex items-center justify-between p-3 rounded-md hover:bg-canvas-soft-2 cursor-pointer text-sm text-ink font-medium select-none group" data-command="project">
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 text-xs font-mono bg-warning-soft/30 text-warning-deep border border-warning-soft/20 rounded-sm">/project</span>
          <span class="text-body group-hover:text-ink">Switch sidebar category view <span class="text-mute font-normal text-xs ml-1">(e.g., /project Work)</span></span>
        </div>
        <span class="text-xs font-mono text-mute bg-canvas-soft border border-hairline px-1 rounded-sm hidden group-hover:block">↵</span>
      </div>

      <!-- Option Template (Clear completed) -->
      <div class="command-option flex items-center justify-between p-3 rounded-md hover:bg-canvas-soft-2 cursor-pointer text-sm text-ink font-medium select-none group" data-command="clear">
        <div class="flex items-center gap-3">
          <span class="px-2 py-0.5 text-xs font-mono bg-canvas-soft border border-hairline text-mute rounded-sm">/clear</span>
          <span class="text-body group-hover:text-ink">Delete all completed tasks</span>
        </div>
        <span class="text-xs font-mono text-mute bg-canvas-soft border border-hairline px-1 rounded-sm hidden group-hover:block">↵</span>
      </div>
    </div>

    <!-- Modal Footer Help -->
    <div class="px-4 py-2 border-t border-hairline bg-canvas-soft flex items-center justify-between text-[10px] font-mono text-mute">
      <div class="flex items-center gap-3">
        <span>↑↓ Navigation</span>
        <span>↵ Execute</span>
      </div>
      <span>Type "/" to toggle command list</span>
    </div>
  </div>
</div>
