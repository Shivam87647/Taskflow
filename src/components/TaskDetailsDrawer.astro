---
// TaskDetailsDrawer component for editing subtasks, notes, project and due dates
---
<!-- Sidebar Drawer overlay -->
<div 
  id="drawer-overlay" 
  class="fixed inset-0 z-30 bg-primary/5 backdrop-blur-[1px] hidden transition-opacity duration-200"
></div>

<!-- Drawer container -->
<aside 
  id="task-details-drawer" 
  class="fixed right-0 top-0 bottom-0 z-40 w-full sm:w-96 bg-canvas border-l border-hairline shadow-level5 translate-x-full transition-transform duration-200 ease-in-out flex flex-col font-sans"
>
  <!-- Drawer Header -->
  <div class="h-16 px-6 border-b border-hairline flex items-center justify-between">
    <div class="flex items-center gap-2">
      <span class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm" id="drawer-task-id">
        TASK-00
      </span>
      <span class="text-xs text-mute font-medium">Task Details</span>
    </div>
    <button 
      id="close-drawer-btn" 
      class="p-1 rounded-sm hover:bg-canvas-soft-2 text-mute hover:text-ink cursor-pointer transition-colors"
      aria-label="Close details"
    >
      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Drawer Body -->
  <div class="flex-1 overflow-y-auto p-6 space-y-6">
    <!-- Task Title & Status -->
    <div class="space-y-4">
      <div>
        <label class="text-[10px] font-mono text-mute tracking-wider uppercase block mb-1">Title</label>
        <input 
          type="text" 
          id="drawer-title" 
          class="w-full text-base font-semibold bg-transparent border-0 border-b border-transparent hover:border-hairline focus:border-primary focus:ring-0 px-0 pb-1 text-ink focus:outline-hidden"
          placeholder="Task title"
        />
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="text-[10px] font-mono text-mute tracking-wider uppercase block mb-1">Status</label>
          <select 
            id="drawer-status" 
            class="w-full h-8 px-2 bg-canvas border border-hairline rounded-sm text-xs font-medium text-ink focus:outline-hidden focus:border-primary focus:ring-0"
          >
            <option value="todo">Todo</option>
            <option value="in-progress">In Progress</option>
            <option value="done">Done</option>
          </select>
        </div>
        <div>
          <label class="text-[10px] font-mono text-mute tracking-wider uppercase block mb-1">Priority</label>
          <select 
            id="drawer-priority" 
            class="w-full h-8 px-2 bg-canvas border border-hairline rounded-sm text-xs font-medium text-ink focus:outline-hidden focus:border-primary focus:ring-0"
          >
            <option value="low">Low</option>
            <option value="medium">Medium</option>
            <option value="high">High</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Category & Due Date -->
    <div class="grid grid-cols-2 gap-4 border-t border-hairline pt-6">
      <div>
        <label class="text-[10px] font-mono text-mute tracking-wider uppercase block mb-1">Project</label>
        <select 
          id="drawer-project" 
          class="w-full h-8 px-2 bg-canvas border border-hairline rounded-sm text-xs font-medium text-ink focus:outline-hidden focus:border-primary focus:ring-0"
        >
          <option value="Inbox">Inbox</option>
          <option value="Work">Work</option>
          <option value="Personal">Personal</option>
          <option value="Side Projects">Side Projects</option>
        </select>
      </div>
      <div>
        <label class="text-[10px] font-mono text-mute tracking-wider uppercase block mb-1">Due Date</label>
        <input 
          type="date" 
          id="drawer-due-date" 
          class="w-full h-8 px-2 bg-canvas border border-hairline rounded-sm text-xs font-medium text-ink focus:outline-hidden focus:border-primary focus:ring-0"
        />
      </div>
    </div>

    <!-- Subtasks Checklist -->
    <div class="border-t border-hairline pt-6 space-y-4">
      <div class="flex items-center justify-between">
        <label class="text-[10px] font-mono text-mute tracking-wider uppercase block">Subtasks</label>
        <span id="subtask-progress-text" class="text-[10px] font-mono text-mute">0% (0/0)</span>
      </div>

      <!-- Custom subtask progress bar -->
      <div class="h-1 bg-canvas-soft-2 rounded-full overflow-hidden">
        <div id="subtask-progress-bar" class="h-full bg-success transition-all duration-300 w-0"></div>
      </div>

      <!-- Checklist container -->
      <div id="subtask-list" class="space-y-2">
        <!-- Dynmically loaded subtask rows go here -->
      </div>

      <!-- Add Subtask Input -->
      <div class="flex gap-2">
        <input 
          type="text" 
          id="add-subtask-input" 
          placeholder="Add subtask..." 
          class="flex-1 h-8 px-3 bg-canvas border border-hairline rounded-sm text-xs text-ink focus:outline-hidden focus:border-primary focus:ring-0"
        />
        <button 
          id="add-subtask-btn" 
          class="px-3 h-8 bg-primary text-on-primary hover:bg-ink text-xs font-medium rounded-sm transition-colors cursor-pointer"
        >
          Add
        </button>
      </div>
    </div>

    <!-- Notes / Description -->
    <div class="border-t border-hairline pt-6 space-y-2">
      <label class="text-[10px] font-mono text-mute tracking-wider uppercase block">Notes & Details</label>
      <textarea 
        id="drawer-notes" 
        rows="5" 
        placeholder="Add details, links, or developer instructions..." 
        class="w-full p-3 bg-canvas-soft border border-hairline rounded-sm text-xs text-ink placeholder:text-mute focus:outline-hidden focus:bg-canvas focus:border-primary focus:ring-0 font-mono resize-none leading-relaxed"
      ></textarea>
    </div>
  </div>

  <!-- Drawer Footer Actions -->
  <div class="p-6 border-t border-hairline bg-canvas-soft flex items-center justify-between gap-3">
    <button 
      id="delete-task-btn" 
      class="flex items-center gap-1.5 px-3 py-2 border border-error-soft bg-error-soft/30 hover:bg-error-soft text-error-deep hover:text-error-deep text-xs font-medium rounded-sm transition-colors cursor-pointer"
    >
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
      </svg>
      Delete Task
    </button>
    
    <button 
      id="save-drawer-btn" 
      class="px-4 py-2 bg-primary text-on-primary hover:bg-ink text-xs font-medium rounded-sm transition-colors cursor-pointer"
    >
      Save Changes
    </button>
  </div>
</aside>
