---
// Sidebar component for the Task.sh application
---
<aside 
  id="task-sidebar" 
  class="w-64 bg-canvas border-r border-hairline flex flex-col h-full shrink-0"
>
  <!-- Branding Header -->
  <div class="h-16 border-b border-hairline flex items-center justify-between px-6">
    <div class="flex items-center gap-2">
      <!-- Minimal Vercel-like black triangle logo -->
      <svg class="w-4 h-4 fill-ink" viewBox="0 0 75 65" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M37.5 0L75 65H0L37.5 0Z" />
      </svg>
      <span class="font-sans font-semibold tracking-tight text-md">Task.sh</span>
    </div>
    <span class="text-[10px] font-mono bg-canvas-soft border border-hairline text-body px-1.5 py-0.5 rounded-sm">
      v0.1.0
    </span>
  </div>

  <!-- Primary Navigation -->
  <nav class="flex-1 overflow-y-auto px-4 py-6 space-y-6">
    <div class="space-y-1">
      <button 
        data-sidebar-view="all"
        class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-ink bg-canvas-soft-2 font-medium relative group"
      >
        <!-- Active indicator -->
        <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator"></span>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4" />
          </svg>
          <span>Inbox</span>
        </div>
        <span id="badge-all" class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm group-hover:bg-canvas">0</span>
      </button>

      <button 
        data-sidebar-view="today"
        class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-body hover:text-ink hover:bg-canvas-soft-2 relative group"
      >
        <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator hidden"></span>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
          <span>Today</span>
        </div>
        <span id="badge-today" class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm group-hover:bg-canvas">0</span>
      </button>

      <button 
        data-sidebar-view="backlog"
        class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-body hover:text-ink hover:bg-canvas-soft-2 relative group"
      >
        <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator hidden"></span>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          <span>Backlog</span>
        </div>
        <span id="badge-backlog" class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm group-hover:bg-canvas">0</span>
      </button>
    </div>

    <!-- Projects Section -->
    <div class="space-y-2">
      <div class="px-3 text-[10px] font-mono tracking-wider text-mute uppercase">Projects</div>
      <div class="space-y-1">
        <button 
          data-sidebar-view="project-Work"
          class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-body hover:text-ink hover:bg-canvas-soft-2 relative group"
        >
          <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator hidden"></span>
          <div class="flex items-center gap-2.5">
            <span class="w-2.5 h-2.5 rounded-full border border-violet-soft bg-violet-deep flex-shrink-0"></span>
            <span>Work</span>
          </div>
          <span id="badge-project-Work" class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm group-hover:bg-canvas">0</span>
        </button>

        <button 
          data-sidebar-view="project-Personal"
          class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-body hover:text-ink hover:bg-canvas-soft-2 relative group"
        >
          <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator hidden"></span>
          <div class="flex items-center gap-2.5">
            <span class="w-2.5 h-2.5 rounded-full border border-cyan-soft bg-cyan-deep flex-shrink-0"></span>
            <span>Personal</span>
          </div>
          <span id="badge-project-Personal" class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm group-hover:bg-canvas">0</span>
        </button>

        <button 
          data-sidebar-view="project-Side Projects"
          class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-body hover:text-ink hover:bg-canvas-soft-2 relative group"
        >
          <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator hidden"></span>
          <div class="flex items-center gap-2.5">
            <span class="w-2.5 h-2.5 rounded-full border border-warning-soft bg-warning-deep flex-shrink-0"></span>
            <span>Side Projects</span>
          </div>
          <span id="badge-project-Side" class="text-xs font-mono bg-canvas-soft border border-hairline text-mute px-1.5 py-0.5 rounded-sm group-hover:bg-canvas">0</span>
        </button>
      </div>
    </div>

    <!-- Analytics Dashboard Switcher -->
    <div class="space-y-1">
      <div class="px-3 text-[10px] font-mono tracking-wider text-mute uppercase mb-2">Metrics</div>
      <button 
        data-sidebar-view="dashboard"
        class="sidebar-nav-btn w-full flex items-center justify-between px-3 py-2 text-sm rounded-md transition-colors duration-150 text-body hover:text-ink hover:bg-canvas-soft-2 relative group"
      >
        <span class="absolute left-0 top-2 bottom-2 w-[3px] bg-primary rounded-r-full sidebar-active-indicator hidden"></span>
        <div class="flex items-center gap-2.5">
          <svg class="w-4 h-4 text-body" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 002 2h2a2 2 0 002-2z" />
          </svg>
          <span>Metrics & Stats</span>
        </div>
      </button>
    </div>
  </nav>

  <!-- Interactive Mock Deployment Card -->
  <div class="p-4 border-t border-hairline bg-canvas-soft">
    <div class="p-3 bg-canvas border border-hairline rounded-md shadow-level2 space-y-2">
      <div class="flex items-center justify-between">
        <span class="text-[10px] font-mono text-mute tracking-wider uppercase">Deployment</span>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-success animate-pulse"></span>
          <span class="text-[10px] font-mono text-success">Active</span>
        </div>
      </div>
      <div class="text-xs font-semibold truncate">task-sh-prod.vercel.app</div>
      <div class="flex items-center justify-between text-[10px] font-mono text-mute pt-1 border-t border-hairline">
        <span>Usage</span>
        <span>Local-first</span>
      </div>
    </div>
  </div>
</aside>
